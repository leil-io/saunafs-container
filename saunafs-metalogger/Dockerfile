
ARG BASE_IMAGE=saunafs-base:ubuntu-24.04
FROM ${BASE_IMAGE}

# Allow version pinning: --build-arg SAUNAFS_VERSION=5.8.0-1
ARG SAUNAFS_VERSION=""
RUN apt-get update && \
	if [ -z "$SAUNAFS_VERSION" ]; then \
		apt-get install -y saunafs-metalogger; \
	else \
		apt-get install -y saunafs-metalogger="$SAUNAFS_VERSION"; \
	fi && \
	apt-get clean && \
	rm -rf /var/lib/apt/lists/*

COPY saunafs-metalogger.start.sh saunafs-metalogger.start.sh
RUN chmod +x saunafs-metalogger.start.sh

CMD ["./saunafs-metalogger.start.sh"]
